generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts    Account[]
  sessions    Session[]
  savedMovies SavedMovie[]
  MovieReaction MovieReaction[]
 
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedMovie {
  id        String   @id @default(cuid())
  title     String
  image     String?
  type      String // movie or series
  userId    String
  tmdbId    Int?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, title])
}

model Url {
  id          Int      @id @default(autoincrement())
  shortCode   String   @unique
  originalUrl String
  createdAt   DateTime @default(now())
}

model MovieReaction {
  id        String   @id @default(cuid())
  title     String
  image     String?
  type      String        // "movie" or "tv"
  tmdbId    Int?
  reaction  String        // "like" or "dislike"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, title]) // prevents duplicate reactions on same movie
}